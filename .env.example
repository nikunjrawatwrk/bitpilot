# Bitbucket credentials (can also be set via the Settings UI)
BITBUCKET_WORKSPACE=your-workspace-slug
BITBUCKET_EMAIL=you@example.com
BITBUCKET_USERNAME=your-username
BITBUCKET_TOKEN=your-app-password

# AI provider — choose one: openai | claude | claude-cli
AI_PROVIDER=openai

# OpenAI (if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Claude API (if AI_PROVIDER=claude)
CLAUDE_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# Claude CLI (if AI_PROVIDER=claude-cli)
# No key needed — uses the locally installed `claude` CLI
# CLAUDE_BIN=/usr/local/bin/claude   # optional: override path to claude binary

# Deployment notifications
ZOHO_CLIQ_WEBHOOK_URL=https://cliq.zoho.in/api/v2/channelsbyname/your-channel/message?zapikey=...
DEPLOY_WEBHOOK_URL=https://hooks.slack.com/services/...
DEPLOY_WEBHOOK_KEY=optional-bearer-token

# Server port (default: 3001)
# PORT=3001
